{
code = "sub bullet by periodcentered;

lookup point {
    sub period period by periodcentered;
    sub period period period by ellipsis;
      } point;

lookup ligaturasinclusivas {
sub a periodcentered e by a_e;
sub a periodcentered o by a_o;
sub o periodcentered a by a_e.ss02;
sub a o periodcentered e by a_o_e;
sub e a periodcentered u by e_a_u;
sub agrave periodcentered a o by a_e.ss02;
      } ligaturasinclusivas;
";
